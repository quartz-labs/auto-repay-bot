{
  "name": "auto-repay-bot",
  "version": "0.1.0",
  "description": "Bot for calling auto-repay instructions on the Quartz protocol",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "NODE_ENV=development tsx src/index.ts",
    "start": "tsc -p tsconfig.json && node build/index.js",
    "lint": "yarn biome lint --write",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quartz-labs/auto-repay-bot.git"
  },
  "author": "Quartz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/quartz-labs/auto-repay-bot/issues"
  },
  "homepage": "https://github.com/quartz-labs/auto-repay-bot#readme",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.696.0",
    "@coral-xyz/anchor": "0.29.0",
    "@jup-ag/api": "^6.0.29",
    "@mrgnlabs/marginfi-client-v2": "^4.0.0",
    "@quartz-labs/sdk": "^0.0.12",
    "@solana/spl-token": "0.3.11",
    "@solana/web3.js": "1.92.3",
    "@types/node": "^22.10.0",
    "bignumber.js": "^9.1.2",
    "express": "^4.21.1",
    "nodemailer": "^6.9.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "resolutions": {
    "@solana/web3.js": "1.92.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^6.4.17"
  }
}
